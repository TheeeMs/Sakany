### Sakany API Complete Sequential Test Flow (54 Endpoints)
# This file is compatible with IntelliJ IDEA HTTP Client and VS Code REST Client.
# It uses variables to chain requests sequentially.

@host = http://localhost:8080
@email = testuser+{{$timestamp}}@example.com
@password = Password123!
@phone = +12345{{$timestamp}}
@otp_code = 123456
@visit_log_id = 
@event_id_reject = 
@notification_id = 

# ==========================================
# 1. AUTHENTICATION & USERS
# ==========================================

### Register User
# @name registerUser
POST {{host}}/v1/auth/register
Content-Type: application/json

{
  "firstName": "Admin",
  "lastName": "User",
  "phoneNumber": "{{phone}}",
  "email": "{{email}}",
  "password": "{{password}}",
  "type": "PROPERTY_OWNER",
  "loginMethod": "EMAIL_PASSWORD"
}

> {%
    client.global.set("auth_token", response.body.accessToken);
    client.global.set("refresh_token", response.body.refreshToken);
    client.global.set("user_id", response.body.userId);
%}

### Send OTP
# @name sendOtp
POST {{host}}/v1/auth/send-otp
Content-Type: application/json

{
  "phoneNumber": "{{phone}}"
}

> {%
    if (response.body && response.body.otpCode) {
      client.global.set("otp_code", response.body.otpCode);
    }
%}

### Login with Phone
POST {{host}}/v1/auth/login/phone
Content-Type: application/json

{
  "phoneNumber": "{{phone}}",
  "otpCode": "{{otp_code}}"
}

### Login with Email
# @name loginEmail
POST {{host}}/v1/auth/login/email
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

> {%
    client.global.set("auth_token", response.body.accessToken);
%}

### Refresh Token
POST {{host}}/v1/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refresh_token}}"
}

### Get Current User (Assuming /v1/auth/me exists)
GET {{host}}/v1/auth/me
Authorization: Bearer {{auth_token}}

# ==========================================
# 2. DEVICE TOKENS
# ==========================================

### Register Device Token
# @name registerDeviceToken
POST {{host}}/v1/device-tokens
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "userId": "{{user_id}}",
  "token": "dummy-fcm-token-12345",
  "platform": "WEB"
}

### Deactivate Device Token (Needs actual token ID returned from above, assuming UUID)
DELETE {{host}}/v1/device-tokens/some-uuid-here
Authorization: Bearer {{auth_token}}


# ==========================================
# 3. PROPERTIES (COMPOUND, BUILDING, UNIT)
# ==========================================

### Create Compound
# @name createCompound
POST {{host}}/v1/compounds
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "name": "Sunset Paradise Real Estate",
  "address": "123 Main St, City"
}

> {% client.global.set("compound_id", response.body); %}

### Get Compound by ID
GET {{host}}/v1/compounds/{{compound_id}}
Authorization: Bearer {{auth_token}}

### Create Building
# @name createBuilding
POST {{host}}/v1/buildings
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "compoundId": "{{compound_id}}",
  "name": "Building A",
  "numberOfFloors": 10
}

> {% client.global.set("building_id", response.body); %}

### Get Buildings by Compound
GET {{host}}/v1/buildings/compound/{{compound_id}}
Authorization: Bearer {{auth_token}}

### Create Unit
# @name createUnit
POST {{host}}/v1/units
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "buildingId": "{{building_id}}",
  "unitNumber": "101A",
  "floor": 1,
  "type": "APARTMENT"
}

> {% client.global.set("unit_id", response.body); %}

### Get Units by Building
GET {{host}}/v1/units/building/{{building_id}}
Authorization: Bearer {{auth_token}}


# ==========================================
# 4. MAINTENANCE REQUESTS
# ==========================================

### Create Maintenance Request
# @name createMaintenanceReq
POST {{host}}/v1/maintenance-requests
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "residentId": "{{user_id}}",
  "unitId": "{{unit_id}}",
  "title": "Leaking Pipe in Kitchen",
  "description": "Water is leaking from under the sink.",
  "category": "PLUMBING",
  "priority": "URGENT",
  "isPublic": false,
  "photoUrls": []
}

> {% client.global.set("maintenance_id", response.body); %}

### Get Request by ID
GET {{host}}/v1/maintenance-requests/{{maintenance_id}}
Authorization: Bearer {{auth_token}}

### Get by Resident
GET {{host}}/v1/maintenance-requests/resident/{{user_id}}
Authorization: Bearer {{auth_token}}

### Get by Status
GET {{host}}/v1/maintenance-requests/status/SUBMITTED
Authorization: Bearer {{auth_token}}

### Assign Technician
POST {{host}}/v1/maintenance-requests/{{maintenance_id}}/assign
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "technicianId": "tech-uuid-here"
}

### Start Work
POST {{host}}/v1/maintenance-requests/{{maintenance_id}}/start
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{}

### Resolve Work
POST {{host}}/v1/maintenance-requests/{{maintenance_id}}/resolve
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{}

### Reject Work
POST {{host}}/v1/maintenance-requests/{{maintenance_id}}/reject
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "reason": "Not enough parts"
}

### Cancel Work
POST {{host}}/v1/maintenance-requests/{{maintenance_id}}/cancel
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{}


# ==========================================
# 5. INVOICES & PAYMENTS
# ==========================================

### Create Invoice
# @name createInvoice
POST {{host}}/v1/invoices
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "residentId": "{{user_id}}",
  "unitId": "{{unit_id}}",
  "type": "MAINTENANCE_FEE",
  "amount": 150.00,
  "currency": "USD",
  "description": "Fixing the leaking pipe",
  "dueDate": "2026-05-01T00:00:00Z"
}

> {% client.global.set("invoice_id", response.body.id); %}

### List Invoices
GET {{host}}/v1/invoices?residentId={{user_id}}
Authorization: Bearer {{auth_token}}

### Get Invoice by ID
GET {{host}}/v1/invoices/{{invoice_id}}
Authorization: Bearer {{auth_token}}

### Pay Invoice
# @name payInvoice
POST {{host}}/v1/invoices/{{invoice_id}}/pay
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "residentId": "{{user_id}}",
  "paymentMethod": "CREDIT_CARD",
  "transactionReference": "tx-987654321"
}

### List Payments
GET {{host}}/v1/payments?residentId={{user_id}}
Authorization: Bearer {{auth_token}}

### Cancel Invoice
PATCH {{host}}/v1/invoices/{{invoice_id}}/cancel
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{}


# ==========================================
# 6. FEEDBACK
# ==========================================

### Submit Feedback
# @name submitFeedback
POST {{host}}/v1/feedback
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "title": "Great Service",
  "content": "The maintenance guy was really fast.",
  "type": "SUGGESTION",
  "isPublic": true,
  "category": "MAINTENANCE",
  "location": "Building A",
  "isAnonymous": false,
  "imageUrl": null
}

> {% client.global.set("feedback_id", response.body); %}

### Get Public Feedback
GET {{host}}/v1/feedback
Authorization: Bearer {{auth_token}}

### Get My Feedback
GET {{host}}/v1/feedback/me
Authorization: Bearer {{auth_token}}

### Vote on Feedback
POST {{host}}/v1/feedback/{{feedback_id}}/vote
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "voteType": "UP"
}

### Update Feedback Status
PATCH {{host}}/v1/feedback/{{feedback_id}}/status
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "newStatus": "UNDER_REVIEW"
}

### Admin Feedback Dashboard
GET {{host}}/v1/admin/feedback?tab=PUBLIC_SUGGESTIONS&status=ALL&page=0&size=25
Authorization: Bearer {{auth_token}}

### Admin Feedback Status Options
GET {{host}}/v1/admin/feedback/statuses
Authorization: Bearer {{auth_token}}

### Admin Feedback Category Options
GET {{host}}/v1/admin/feedback/categories
Authorization: Bearer {{auth_token}}

### Admin Feedback Details
GET {{host}}/v1/admin/feedback/{{feedback_id}}/details
Authorization: Bearer {{auth_token}}

### Admin Create Feedback
POST {{host}}/v1/admin/feedback
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "selectedResidentId": "{{user_id}}",
  "visibility": "PUBLIC",
  "title": "Add More Benches in the Garden Area",
  "detailedDescription": "Residents need more shaded seating near the playground.",
  "selectedCategory": "Facilities",
  "location": "Garden Area",
  "postAnonymously": false,
  "photoUrls": []
}

### Admin Respond to Feedback
PATCH {{host}}/v1/admin/feedback/{{feedback_id}}/respond
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "response": "Thanks for the suggestion. The maintenance team will add this to next week plan.",
  "newStatus": "UNDER_REVIEW"
}

### Admin Update Feedback Status (UI-Mapped)
PATCH {{host}}/v1/admin/feedback/{{feedback_id}}/status
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "newStatus": "RESOLVED"
}

### Admin Delete Feedback
DELETE {{host}}/v1/admin/feedback/{{feedback_id}}
Authorization: Bearer {{auth_token}}


