### Sakany API Complete Sequential Test Flow (94 Endpoints)
# This file is compatible with IntelliJ IDEA HTTP Client and VS Code REST Client.
# It uses variables to chain requests sequentially.

@host = http://localhost:8080
@email = testuser+{{$timestamp}}@example.com
@password = Password123!
@phone = +12345{{$timestamp}}
@admin_token = {{auth_token}}
@resident_email = resident+{{$timestamp}}@example.com
@resident_phone = +2012{{$timestamp}}
@otp_code = 123456
@resident_id = 
@visit_log_id = 
@event_id_reject = 
@notification_id = 

# ==========================================
# 1. AUTHENTICATION & USERS
# ==========================================

### Register User
# @name registerUser
POST {{host}}/v1/auth/register
Content-Type: application/json

{
  "firstName": "Admin",
  "lastName": "User",
  "phoneNumber": "{{phone}}",
  "email": "{{email}}",
  "password": "{{password}}",
  "type": "PROPERTY_OWNER",
  "loginMethod": "EMAIL_PASSWORD"
}

> {%
    client.global.set("auth_token", response.body.accessToken);
    client.global.set("refresh_token", response.body.refreshToken);
    client.global.set("user_id", response.body.userId);
%}

### Send OTP
# @name sendOtp
POST {{host}}/v1/auth/send-otp
Content-Type: application/json

{
  "phoneNumber": "{{phone}}"
}

> {%
    if (response.body && response.body.otpCode) {
      client.global.set("otp_code", response.body.otpCode);
    }
%}

### Login with Phone
POST {{host}}/v1/auth/login/phone
Content-Type: application/json

{
  "phoneNumber": "{{phone}}",
  "otpCode": "{{otp_code}}"
}

### Login with Email
# @name loginEmail
POST {{host}}/v1/auth/login/email
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

> {%
    client.global.set("auth_token", response.body.accessToken);
%}

### Refresh Token
POST {{host}}/v1/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refresh_token}}"
}

### Get Current User (Assuming /v1/auth/me exists)
GET {{host}}/v1/auth/me
Authorization: Bearer {{auth_token}}

# ==========================================
# 2. DEVICE TOKENS
# ==========================================

### Register Device Token
# @name registerDeviceToken
POST {{host}}/v1/device-tokens
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "userId": "{{user_id}}",
  "token": "dummy-fcm-token-12345",
  "platform": "WEB"
}

### Deactivate Device Token (Needs actual token ID returned from above, assuming UUID)
DELETE {{host}}/v1/device-tokens/some-uuid-here
Authorization: Bearer {{auth_token}}


