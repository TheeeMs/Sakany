### Report Alert
# @name reportAlert
POST {{host}}/v1/alerts
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "reporterId": "{{user_id}}",
  "type": "SUSPICIOUS_ACTIVITY",
  "category": "PERSON",
  "title": "Suspicious person in lobby",
  "description": "Someone is wandering around without access card.",
  "location": "Building A Lobby",
  "eventTime": "2026-04-16T10:00:00Z",
  "photoUrls": [],
  "contactNumber": "+201000000000"
}

> {% client.global.set("alert_id", response.body.id || response.body); %}

### Get Active Alerts
GET {{host}}/v1/alerts
Authorization: Bearer {{auth_token}}

### Get Alert by ID
GET {{host}}/v1/alerts/{{alert_id}}
Authorization: Bearer {{auth_token}}

### Resolve Alert
PATCH {{host}}/v1/alerts/{{alert_id}}/resolve
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "requestingUserId": "{{user_id}}"
}


# ==========================================
# 9. ADMIN MISSING & FOUND
# ==========================================

### Admin List Missing & Found Reports
GET {{host}}/v1/admin/missing-found/reports?search=&type=ALL&status=ALL&category=&page=0&size=10
Authorization: Bearer {{auth_token}}

### Admin Missing & Found Summary
GET {{host}}/v1/admin/missing-found/summary?search=&type=ALL&status=ALL&category=
Authorization: Bearer {{auth_token}}

### Admin Get Report by ID
GET {{host}}/v1/admin/missing-found/reports/{{alert_id}}
Authorization: Bearer {{auth_token}}

### Admin Resident Options for "Report On Behalf Of" Dropdown
GET {{host}}/v1/admin/missing-found/residents/options?search=&page=0&size=25
Authorization: Bearer {{auth_token}}

### Admin Create Missing & Found Report (UI Alias Contract)
# @name adminCreateMissingFoundReport
POST {{host}}/v1/admin/missing-found/reports
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "reportOnBehalfOf": "{{user_id}}",
  "reportType": "Missing",
  "itemCategory": "Personal Item",
  "briefDescription": "Car Keys with Blue Keychain",
  "detailedDescription": "Lost my car keys with a blue leather keychain.",
  "lastSeenLocation": "Near swimming pool area",
  "lastSeenAt": "2026-02-11T10:00:00Z",
  "photos": [],
  "contactNumber": "+201000000000"
}

> {% client.global.set("admin_report_id", response.body.id || response.body); %}

### Admin Update Missing & Found Report
PATCH {{host}}/v1/admin/missing-found/reports/{{admin_report_id}}
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "title": "Car Keys with Blue Keychain (Updated)",
  "detailedDescription": "Updated details from admin dashboard edit action.",
  "lastSeenLocation": "Near clubhouse entrance",
  "photos": []
}

### Admin Update Missing & Found Status
PATCH {{host}}/v1/admin/missing-found/reports/{{admin_report_id}}/status
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "newStatus": "MATCHED"
}

### Admin Get Missing & Found Type Options
GET {{host}}/v1/admin/missing-found/types
Authorization: Bearer {{auth_token}}

### Admin Get Missing & Found Status Options
GET {{host}}/v1/admin/missing-found/statuses
Authorization: Bearer {{auth_token}}

### Admin Get Missing & Found Category Options
GET {{host}}/v1/admin/missing-found/categories
Authorization: Bearer {{auth_token}}

### Admin Delete Missing & Found Report
DELETE {{host}}/v1/admin/missing-found/reports/{{admin_report_id}}
Authorization: Bearer {{auth_token}}


# ==========================================
# 10. ACCESS CODES (VISITORS)
# ==========================================

### Create Access Code
# @name createAccessCode
POST {{host}}/v1/access/codes
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "visitorName": "John Doe",
  "visitorPhone": "+19876543210",
  "purpose": "Visiting for dinner",
  "isSingleUse": true,
  "validFrom": "2026-04-16T10:00:00Z",
  "validUntil": "2026-04-17T10:00:00Z"
}

> {% 
    client.global.set("access_code_id", response.body.id); 
    client.global.set("access_code_str", response.body.code); 
%}

### Get Access Code
GET {{host}}/v1/access/codes/{{access_code_id}}
Authorization: Bearer {{auth_token}}

### List My Access Codes
GET {{host}}/v1/access/codes/my
Authorization: Bearer {{auth_token}}

### Scan Access Code
# @name scanAccessCode
POST {{host}}/v1/access/codes/{{access_code_str}}/scan
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "gateNumber": 1
}

> {%
    client.global.set("visit_log_id", response.body.visitLogId);
%}

### Reactivate Access Code
POST {{host}}/v1/access/codes/{{access_code_id}}/reactivate
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "validFrom": "2026-04-18T10:00:00Z",
  "validUntil": "2026-04-19T10:00:00Z"
}

### List Visit Logs
GET {{host}}/v1/access/visit-logs
Authorization: Bearer {{auth_token}}

### Log Visitor Exit
PATCH {{host}}/v1/access/visit-logs/{{visit_log_id}}/exit
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{}

### Revoke Access Code
DELETE {{host}}/v1/access/codes/{{access_code_id}}
Authorization: Bearer {{auth_token}}


# ==========================================
# 10. EVENTS
# ==========================================

### Propose Event
# @name proposeEvent
POST {{host}}/v1/events
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "organizerId": "{{user_id}}",
  "title": "Community BBQ",
  "description": "Annual summer BBQ event for all residents.",
  "startDate": "2027-06-01T14:00:00Z",
  "endDate": "2027-06-01T18:00:00Z",
  "location": "Main Pool Area",
  "maxAttendees": 50,
  "category": "SOCIAL",
  "hostName": "Community Team",
  "hostRole": "ADMIN",
  "contactPhone": "+1234567890",
  "price": 0,
  "latitude": 30.0444,
  "longitude": 31.2357
}

> {%
    const location = response.headers["location"] || response.headers["Location"];
    if (location) {
      client.global.set("event_id", location.split("/").pop());
    }
%}

### List Events
GET {{host}}/v1/events?status=PROPOSED
Authorization: Bearer {{auth_token}}

### Get Event Details
GET {{host}}/v1/events/{{event_id}}
Authorization: Bearer {{auth_token}}

### Approve Event
PATCH {{host}}/v1/events/{{event_id}}/approve?adminId={{user_id}}
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{}

### Propose Event For Reject Path
# @name proposeEventReject
POST {{host}}/v1/events
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "organizerId": "{{user_id}}",
  "title": "Community Cleanup",
  "description": "Cleanup day for all residents.",
  "startDate": "2027-07-01T09:00:00Z",
  "endDate": "2027-07-01T12:00:00Z",
  "location": "Central Garden",
  "maxAttendees": 30,
  "category": "COMMUNITY",
  "hostName": "Community Team",
  "hostRole": "ADMIN",
  "contactPhone": "+1234567890",
  "price": 0,
  "latitude": 30.0444,
  "longitude": 31.2357
}

> {%
    const location = response.headers["location"] || response.headers["Location"];
    if (location) {
      client.global.set("event_id_reject", location.split("/").pop());
    }
%}

### Reject Event
PATCH {{host}}/v1/events/{{event_id_reject}}/reject?adminId={{user_id}}
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{}

### Register for Event
POST {{host}}/v1/events/{{event_id}}/register?residentId={{user_id}}
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{}

### Cancel Registration
DELETE {{host}}/v1/events/{{event_id}}/register?residentId={{user_id}}
Authorization: Bearer {{auth_token}}


# ==========================================
# 11. NOTIFICATIONS
# ==========================================

### Send Notification
# @name sendNotification
POST {{host}}/v1/notifications/send
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "recipientId": "{{user_id}}",
  "title": "Welcome to Sakany!",
  "body": "Your account has been successfully set up.",
  "type": "ANNOUNCEMENT",
  "referenceId": null,
  "channel": "PUSH"
}

> {%
    client.global.set("notification_id", response.body);
%}

### List Notifications
GET {{host}}/v1/notifications?recipientId={{user_id}}
Authorization: Bearer {{auth_token}}

### Mark Notification as Read (Depends on getting id from above)
PATCH {{host}}/v1/notifications/{{notification_id}}/read?recipientId={{user_id}}
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{}

### Mark All as Read
PATCH {{host}}/v1/notifications/read-all?recipientId={{user_id}}
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{}
