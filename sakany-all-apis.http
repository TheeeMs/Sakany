Authorization: Bearer {{auth_token}}


# ==========================================
# 4. ADMIN RESIDENT DIRECTORY (ADMIN)
# ==========================================

### List Resident Buildings (Filter Dropdown)
GET {{host}}/v1/admin/residents/buildings
Authorization: Bearer {{admin_token}}

### List Resident Units (Assign Unit Dropdown)
GET {{host}}/v1/admin/residents/units?buildingId={{building_id}}
Authorization: Bearer {{admin_token}}

### Create Resident (Admin)
# @name createAdminResident
POST {{host}}/v1/admin/residents
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "firstName": "Resident",
  "lastName": "One",
  "phoneNumber": "{{resident_phone}}",
  "email": "{{resident_email}}",
  "password": "{{password}}",
  "type": "TENANT",
  "unitId": "{{unit_id}}",
  "loginMethod": "EMAIL_PASSWORD",
  "approvalStatus": "PENDING",
  "moveInDate": "2026-04-16",
  "monthlyFee": 2500,
  "nationalId": "29012345678901"
}

> {%
    client.global.set("resident_id", response.body);
%}

### List Residents Directory (Admin)
# @name listAdminResidents
GET {{host}}/v1/admin/residents?search=Resident&buildingId={{building_id}}&status=PENDING&approvalStatus=PENDING&page=0&size=25
Authorization: Bearer {{admin_token}}

> {%
    if ((!client.global.get("resident_id") || client.global.get("resident_id") === "")
        && response.body
        && response.body.residents
        && response.body.residents.length > 0) {
      client.global.set("resident_id", response.body.residents[0].residentId);
    }
%}

### Get Resident Details (Admin)
GET {{host}}/v1/admin/residents/{{resident_id}}
Authorization: Bearer {{admin_token}}

### Get Resident Card (Admin)
GET {{host}}/v1/admin/residents/{{resident_id}}/card
Authorization: Bearer {{admin_token}}

### Update Resident Details (Admin)
PATCH {{host}}/v1/admin/residents/{{resident_id}}
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "firstName": "Resident Updated",
  "lastName": "One",
  "phoneNumber": "{{resident_phone}}",
  "email": "{{resident_email}}",
  "isActive": true,
  "unitId": "{{unit_id}}",
  "type": "TENANT",
  "moveInDate": "2026-04-16",
  "monthlyFee": 2500,
  "nationalId": "29012345678901"
}

### Reset Resident Password (Admin)
POST {{host}}/v1/admin/residents/{{resident_id}}/reset-password
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{}

### Approve/Reject Resident (Admin)
PATCH {{host}}/v1/admin/residents/{{resident_id}}/approval
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "approvalStatus": "APPROVED"
}

### Deactivate Resident (Admin)
DELETE {{host}}/v1/admin/residents/{{resident_id}}
Authorization: Bearer {{admin_token}}


# ==========================================
# 5. MAINTENANCE REQUESTS
# ==========================================

### Create Maintenance Request
# @name createMaintenanceReq
POST {{host}}/v1/maintenance-requests
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "residentId": "{{user_id}}",
  "unitId": "{{unit_id}}",
  "title": "Leaking Pipe in Kitchen",
  "description": "Water is leaking from under the sink.",
  "locationLabel": "Unit 101A",
  "category": "PLUMBING",
  "priority": "URGENT",
  "isPublic": false,
  "photoUrls": []
}

> {% client.global.set("maintenance_id", response.body); %}

